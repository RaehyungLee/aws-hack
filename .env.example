NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Use "anthropic" when you only have a Claude API key.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Optional. Strands will use your configured AWS credentials/model access.
AWS_REGION=us-east-1
